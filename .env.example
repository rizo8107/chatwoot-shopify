# InsForge backend (cloud Postgres) — REQUIRED. The app stores all data here.
# Get it with: npx @insforge/cli db connection-string
INSFORGE_DATABASE_URL=postgresql://postgres:PASSWORD@HOST.database.insforge.app:5432/insforge

# InsForge API — REQUIRED. Also used as the identity provider for dashboard login.
INSFORGE_URL=https://your-app.region.insforge.app
INSFORGE_ANON_KEY=anon_xxx
INSFORGE_API_KEY=ik_xxx

# App session signing secret (optional — derived from INSFORGE_API_KEY if unset)
# AUTH_SECRET=

PORT=3000
